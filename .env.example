# Supabase — get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Stripe webhook signing secret — from https://dashboard.stripe.com/webhooks
# Point webhook to: https://YOUR_DOMAIN/api/webhooks/stripe
# Event to enable: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://portal.heavenlyarbor.com

# GoHighLevel (LeadConnector) — from GHL Settings > Integrations > API Keys
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_ghl_location_id

# Business info displayed to customers in SMS, email, and UI
NEXT_PUBLIC_PHONE_NUMBER=(210) 815-5498
GOOGLE_REVIEW_LINK=https://g.page/r/YOUR_REAL_REVIEW_LINK/review
